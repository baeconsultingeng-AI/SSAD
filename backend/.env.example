SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
API_AUTH_KEY=CHANGE_ME_LONG_RANDOM_VALUE
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000
FLASK_DEBUG=0

# AI model routing (optional; required only when live AI extraction is enabled)
AI_ROUTING_ENABLED=false
AI_PRIMARY_PROVIDER=anthropic
AI_PRIMARY_MODEL=
ANTHROPIC_API_KEY=
AI_FALLBACK_1_PROVIDER=openai
AI_FALLBACK_1_MODEL=
OPENAI_API_KEY=
AI_FALLBACK_2_PROVIDER=deepseek
AI_FALLBACK_2_MODEL=
DEEPSEEK_API_KEY=
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES_PER_PROVIDER=1
